# Supabase (push notifications, leads, admin auth)
# Project URL and anon key go in NEXT_PUBLIC_* so the browser can use them
# (they are safe to expose; row-level security protects the data).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
# Service role key bypasses RLS, used by /api/* routes only — keep secret.
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...

# Admin panel access — only this email can log in at /admin/push.
# Create the user in Supabase Auth (Authentication → Users → Add User).
NEXT_PUBLIC_ADMIN_EMAIL=ayush@brandverse.tech
ADMIN_EMAIL=ayush@brandverse.tech

# VAPID keys for web push (run `npx web-push generate-vapid-keys` to get these)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=BHxxx...
VAPID_PRIVATE_KEY=oQxxx...
VAPID_CONTACT_EMAIL=ayush@brandverse.tech

