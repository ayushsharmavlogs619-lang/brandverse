# Copy to .env.local for local dev. For Cloudflare Pages, set the same keys in the dashboard.

# Optional: override site URL for form redirects (defaults to https://brandverse.tech)
# NEXT_PUBLIC_SITE_URL=https://brandverse.tech

# Firebase (use your own keys — never commit real secrets)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# AI API Configuration
GOOGLE_GENERATIVE_AI_API_KEY=your_google_gemini_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Analytics & Tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=your_meta_pixel_id
NEXT_PUBLIC_COOKIEBOT_ID=your_cookiebot_id
NEXT_PUBLIC_LINKEDIN_PARTNER_ID=your_linkedin_partner_id
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_search_console_token

# Scheduling & Contact
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username/30min

# Voice AI
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PHONE_NUMBER=+1your-phone-number-here

# Web push (optional — leave unset if not using push)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Forms: all public marketing forms POST to FormSubmit → ayush@brandverse.tech (see lib/forms.ts).
# First time only: submit a test form, then confirm the address in the email FormSubmit sends you.
